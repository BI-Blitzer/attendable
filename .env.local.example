# SQLite (no database server needed)
DATABASE_URL=sqlite+aiosqlite:///event_agent.db

# LM Studio — start LM Studio, load a model (7B+ recommended), enable local server
# Uncomment and set these if you are using LM Studio or another OpenAI-compatible server:
# LLM_MODEL=openai/meta-llama-3.1-8b-instruct
# LLM_API_BASE=http://localhost:1234/v1
# LLM_API_KEY=lm-studio

# SearXNG — optional self-hosted search
# docker run -d -p 8888:8080 -e SEARXNG_SECRET_KEY=changeme searxng/searxng
# SEARXNG_URL=http://localhost:8888/search

# Paid keys — leave blank or set via the setup wizard
ANTHROPIC_API_KEY=
BRAVE_API_KEY=
SERP_API_KEY=
EVENTBRITE_API_KEY=
