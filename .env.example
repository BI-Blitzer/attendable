# Database — SQLite (default, no server needed)
DATABASE_URL=sqlite+aiosqlite:///event_agent.db

# Database — PostgreSQL (optional, uncomment to use instead)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/event_agent

# AI — at least one provider key required
ANTHROPIC_API_KEY=       # for claude-* models (recommended)
OPENAI_API_KEY=          # for gpt-* models
GEMINI_API_KEY=          # for gemini/* models

# LLM config (LiteLLM model string)
# Examples:
#   claude-sonnet-4-6              → Anthropic (needs ANTHROPIC_API_KEY)
#   gpt-4o                         → OpenAI    (needs OPENAI_API_KEY)
#   gemini/gemini-2.0-flash        → Google    (needs GEMINI_API_KEY)
#   openai/meta-llama-3.1-8b-instruct + LLM_API_BASE=http://localhost:1234/v1  → LM Studio
#   ollama/llama3                  → Ollama    (needs LLM_API_BASE=http://localhost:11434)
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=
LLM_API_BASE=

# Search API keys (all optional — falls back to DuckDuckGo if unset)
BRAVE_API_KEY=           # Brave Search — free tier at brave.com/search/api (2k queries/month)
SERP_API_KEY=            # SerpAPI fallback (paid)
SEARXNG_URL=             # Self-hosted SearXNG (e.g. http://localhost:8888/search)

# Event source keys (optional)
EVENTBRITE_API_KEY=
MEETUP_API_KEY=

# Geographic config
CENTER_ZIP=10001
RADIUS_MILES=120
